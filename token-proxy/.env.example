# SoundCloud app credentials — these stay on the NAS and are NEVER shipped in
# the app or committed to git. Copy this file to .env and fill in real values.
SC_CLIENT_ID=
SC_CLIENT_SECRET=

# Shared key the DJfy app presents (X-Proxy-Key / Authorization: Bearer).
# Low-value: it only grants access to this proxy and can be rotated any time.
# Generate one with:  openssl rand -hex 32
PROXY_API_KEY=

# Optional overrides
# LISTEN_ADDR=:8080
# SC_TOKEN_URL=https://api.soundcloud.com/oauth2/token
